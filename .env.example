DATABASE_URL="file:./dev.db"
AUTH_SECRET="generate-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Optional: enables live AI coach responses (otherwise uses built-in mock coach)
OPENAI_API_KEY=""

# Optional: PostHog product analytics. The app silently no-ops if the key is missing,
# so local/dev builds work fine without setting these. Set the project key in
# Vercel envs (production/preview) when you want to start capturing events.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
